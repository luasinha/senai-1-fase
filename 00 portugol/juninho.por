programa {
  funcao inicio() {
   real salario 
   inteiro dias 
   real salariodiario 

   escreva("digite seu salário: ")
   leia(salario)
   escreva("quantos dias trabalhou no mês: ")
   leia(dias)
   salariodiario = salario / dias
   escreva("\n por dia você recebe R$: " + salariodiario)
  
   escreva("\ntestando: " + salario)

  }
}
